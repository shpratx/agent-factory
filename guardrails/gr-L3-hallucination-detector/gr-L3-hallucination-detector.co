# gr-L1-hallucination-detection — Prompt-Only Mode
# Layer: L1 — Enterprise (all agents)
# Uses NeMo's built-in self check output flow

define bot refuse to respond
  "{\"detected\": true, \"verdict\": \"rejected\", \"reason\": \"Output contains hallucinated, fabricated, or unverifiable claims\", \"severity\": \"high\", \"category\": \"hallucination\", \"rail\": \"output\"}"

define bot inform cannot answer
  "{\"detected\": true, \"verdict\": \"rejected\", \"reason\": \"Output contains hallucinated, fabricated, or unverifiable claims\", \"severity\": \"high\", \"category\": \"hallucination\", \"rail\": \"output\"}"

define bot inform answer unknown
  "{\"detected\": true, \"verdict\": \"rejected\", \"reason\": \"Output contains hallucinated, fabricated, or unverifiable claims\", \"severity\": \"high\", \"category\": \"hallucination\", \"rail\": \"output\"}"