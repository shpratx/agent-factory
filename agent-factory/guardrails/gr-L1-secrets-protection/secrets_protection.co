# gr-L1-secrets-protection — Colang Implementation
# Layer: L1 Enterprise — applies to ALL agents
# Triggers: post_execution (output rail)

define flow check secrets protection
  """Detect secrets, API keys, and credentials in output."""
  $has_secrets = execute detect_secrets(text=$bot_message)

  if $has_secrets
    bot block secrets detected
    stop

  $result = execute self_check_output

  if not $result
    bot block secrets detected
    stop

define bot block secrets detected
  "Output blocked: credentials, API keys, or internal system details detected. Secrets must never appear in agent output."
