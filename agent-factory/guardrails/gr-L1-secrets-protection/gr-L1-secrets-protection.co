# gr-L1-secrets-protection — LLM-Driven Colang Implementation
# Layer: L1 — Secrets Protection
# Validation: LLM self_check (pure Colang)
# Python actions preserved in actions.py for reference/hybrid mode

define flow check output secrets
  """LLM validates secrets protection rules on output."""
  $result = execute self_check_output

  if not $result
    bot block L1 secrets protection
    stop

define bot block L1 secrets protection
  "Output blocked: credentials or secrets detected. Internal keys, tokens, and system details must never appear in output."
