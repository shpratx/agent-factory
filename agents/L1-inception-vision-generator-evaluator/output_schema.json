{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "L1-inception-vision-generator-evaluator Output",
  "type": "object",
  "required": ["agent_id", "agent_version", "execution_id", "workflow_execution_id", "status", "content"],
  "properties": {
    "agent_id": {"type": "string", "const": "L1-inception-vision-generator-evaluator"},
    "agent_version": {"type": "string"},
    "execution_id": {"type": "string", "pattern": "^exec-.+$"},
    "workflow_execution_id": {"type": ["string", "null"]},
    "status": {"type": "string", "enum": ["success", "failed"]},
    "content": {
      "type": "object",
      "required": ["type", "schema_version", "items", "execution_summary"],
      "properties": {
        "type": {"type": "string", "const": "vision_document_evaluation"},
        "schema_version": {"type": "string", "const": "1.0"},
        "items": {
          "type": "object",
          "required": ["verdict", "scores", "findings", "artifact"],
          "properties": {
            "verdict": {"type": "string", "enum": ["pass", "fail"]},
            "scores": {
              "type": "object",
              "properties": {
                "faithfulness": {"type": "number", "minimum": 0, "maximum": 1},
                "hallucination": {"type": "number", "minimum": 0, "maximum": 1},
                "domain_grounding": {"type": "number", "minimum": 0, "maximum": 1},
                "specificity": {"type": "number", "minimum": 0, "maximum": 1},
                "consistency": {"type": "number", "minimum": 0, "maximum": 1},
                "completeness": {"type": "number", "minimum": 0, "maximum": 1}
              }
            },
            "findings": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["category", "description", "fix_applied"],
                "properties": {
                  "category": {"type": "string"},
                  "description": {"type": "string"},
                  "fix_applied": {"type": "string"}
                }
              }
            },
            "artifact": {
              "type": "object",
              "required": ["type", "format", "location", "status"],
              "properties": {
                "type": {"type": "string", "const": "vision_document"},
                "format": {"type": "string", "const": "markdown"},
                "location": {"type": "string"},
                "status": {"type": "string", "enum": ["corrected_and_reuploaded", "no_changes_needed"]}
              }
            }
          }
        },
        "execution_summary": {"type": "string", "minLength": 30}
      }
    }
  }
}
