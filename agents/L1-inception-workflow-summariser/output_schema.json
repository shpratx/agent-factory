{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "L1-inception-workflow-summariser Output",
  "type": "object",
  "required": ["agent_id", "agent_version", "execution_id", "workflow_execution_id", "status", "content"],
  "properties": {
    "agent_id": {"type": "string", "const": "L1-inception-workflow-summariser"},
    "agent_version": {"type": "string"},
    "execution_id": {"type": "string", "pattern": "^exec-.+$"},
    "workflow_execution_id": {"type": ["string", "null"], "pattern": "^wf-.+$"},
    "status": {"type": "string", "enum": ["success", "failed"]},
    "content": {
      "type": "object",
      "required": ["type", "schema_version", "items", "execution_summary"],
      "properties": {
        "type": {"type": "string", "const": "workflow_summary"},
        "schema_version": {"type": "string", "const": "1.0"},
        "items": {
          "type": "object",
          "required": ["request_and_intent", "execution_flow", "outcome"],
          "properties": {
            "request_and_intent": {"type": "string", "description": "What triggered the workflow and the goal"},
            "execution_flow": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string"},
              "description": "Ordered list: each entry is 'agent-id: what it produced (status)'"
            },
            "outcome": {"type": "string", "description": "Final verdict: what was delivered, any failures or gaps"}
          }
        },
        "execution_summary": {"type": "string", "description": "Operational audit only: KBs consulted, guardrails evaluated, tools invoked"}
      }
    }
  }
}
