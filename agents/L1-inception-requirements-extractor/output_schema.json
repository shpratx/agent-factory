{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "L1-inception-requirements-extractor-output-v1.0",
  "title": "Requirements Extractor Output",
  "type": "object",
  "required": ["agent_id", "execution_id", "workflow_execution_id", "status", "content"],
  "properties": {
    "agent_id": {"type": "string", "const": "L1-inception-requirements-extractor"},
    "agent_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "execution_id": {"type": "string", "pattern": "^exec-.+$"},
    "workflow_execution_id": {"type": ["string", "null"], "pattern": "^wf-.+$", "description": "Workflow execution ID inherited from upstream or generated if standalone"},
    "status": {"type": "string", "enum": ["success", "failed"], "description": "Whether the agent completed successfully or failed"},
    "input_summary": {
      "type": "object",
      "required": ["source", "parameters"],
      "properties": {
        "source": {"type": "string", "enum": ["direct_input", "agent_output", "file_upload"]},
        "source_agent_id": {"type": ["string", "null"]},
        "parameters": {"type": "object"}
      }
    },
    "content": {
      "type": "object",
      "required": ["type", "schema_version", "items", "execution_summary"],
      "properties": {
        "type": {"type": "string", "const": "prd_document"},
        "schema_version": {"type": "string", "const": "1.0"},
        "items": {
          "type": "object",
          "required": ["product_name", "document_summary", "artifact", "metadata"],
          "properties": {
            "product_name": {"type": "string", "description": "Derived or stated product/feature name"},
            "document_summary": {
              "type": "object",
              "required": ["total_requirements", "functional_requirements_count", "non_functional_requirements_count", "constraints_count", "assumptions_count", "gaps_count", "dependencies_count", "data_requirements_count", "integration_requirements_count", "success_metrics_count", "risks_count"],
              "properties": {
                "total_requirements": {"type": "integer", "minimum": 0},
                "functional_requirements_count": {"type": "integer", "minimum": 0},
                "non_functional_requirements_count": {"type": "integer", "minimum": 0},
                "constraints_count": {"type": "integer", "minimum": 0},
                "assumptions_count": {"type": "integer", "minimum": 0},
                "gaps_count": {"type": "integer", "minimum": 0},
                "dependencies_count": {"type": "integer", "minimum": 0},
                "data_requirements_count": {"type": "integer", "minimum": 0},
                "integration_requirements_count": {"type": "integer", "minimum": 0},
                "success_metrics_count": {"type": "integer", "minimum": 0},
                "risks_count": {"type": "integer", "minimum": 0}
              }
            },
            "artifact": {
              "type": "object",
              "required": ["type", "format", "location"],
              "properties": {
                "type": {"type": "string", "const": "prd_document"},
                "format": {"type": "string", "const": "markdown"},
                "location": {"type": "string", "description": "Blob storage URL where the PRD was uploaded"}
              }
            },
            "metadata": {
              "type": "object",
              "required": ["template_kb_used", "confidence", "extraction_coverage"],
              "properties": {
                "template_kb_used": {"type": "string"},
                "confidence": {"type": "number", "minimum": 0, "maximum": 1},
                "extraction_coverage": {"type": "number", "minimum": 0, "maximum": 1, "description": "Proportion of input content that was captured in requirements"}
              }
            }
          }
        },
        "execution_summary": {"type": "string", "minLength": 50, "description": "Plain-text bullet summary of what was produced, decisions made, reflection findings"}
      }
    }
  }
}
